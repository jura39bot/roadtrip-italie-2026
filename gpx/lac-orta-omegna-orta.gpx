  <wpt lat="45.7989" lon="8.4206">
    <name>Orta San Giulio</name>
    <desc>Village médiéval, embarcadère pour l'île San Giulio (5 min en bateau, ~4€/pers)</desc>
  </wpt>
  <wpt lat="45.7960" lon="8.4150">
    <name>Île San Giulio</name>
    <desc>Île mystique avec basilique romane. Laisser les vélos à quai.</desc>
