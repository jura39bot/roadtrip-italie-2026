  <metadata>
    <name>Lac d'Orta — Omegna → Orta San Giulio</name>
    <desc>Tour du lac d'Orta, ~25 km, facile, familial. Rive ouest puis Orta San Giulio.</desc>
    <time>2026-04-05T09:00:00Z</time>
  </metadata>
  <trk>
    <name>Lac d'Orta — Omegna → Orta San Giulio</name>
    <trkseg>
      <!-- Omegna - départ -->
      <trkpt lat="45.8789" lon="8.4089"><ele>295</ele><name>Omegna - Départ</name></trkpt>
      <trkpt lat="45.8650" lon="8.4050"><ele>294</ele></trkpt>
